#ادرج "سيف_خالص.ع"

عدم عرض_عنوان() {
    اكتب("\x1b[1;36m");
    اكتب_سطر("╔══════════════════════════════════════════╗");
    اكتب_سطر("║     ⚔️  لغة سيف - المساعدة التفاعلية   ║");
    اكتب_سطر("║       أول لغة برمجة عربية مُجمّعة       ║");
    اكتب_سطر("║          صنع في الجزائر 🇩🇿            ║");
    اكتب_سطر("╚══════════════════════════════════════════╝");
    اكتب("\x1b[0m");
}

عدم عرض_قائمة_الاوامر() {
    اكتب("\x1b[1;33m");
    اكتب_سطر("┌────────────────────────────────────────┐");
    اكتب_سطر("│  م = مساعدة    ك = كلمات               │");
    اكتب_سطر("│  ا = انواع     ث = مثال                │");
    اكتب_سطر("│  د = ادخال     ف = ملفات               │");
    اكتب_سطر("│  ن = نصوص      ر = رياضيات             │");
    اكتب_سطر("│  ش = شروط      ت = تكرار               │");
    اكتب_سطر("│  ج = ترجمة     خ = خروج                │");
    اكتب_سطر("└────────────────────────────────────────┘");
    اكتب("\x1b[0m");
}

عدم عرض_الكلمات() {
    اكتب("\x1b[1;35m");
    اكتب_سطر("");
    اكتب_سطر("═══ الكلمات المفتاحية في لغة سيف ═══");
    اكتب("\x1b[0m");
    اكتب_سطر("📌 الشروط: اذا | والا | والا اذا");
    اكتب_سطر("📌 التكرار: طالما | لكل | توقف | استمر");
    اكتب_سطر("📌 التفرع: تفرع | حالة | افتراضي");
    اكتب_سطر("📌 الدوال: ارجع | أرجع | رئيسي");
    اكتب_سطر("📌 الأنواع: عدد | محرف | كسري | مزدوج | عدم");
    اكتب_سطر("📌 القيم: صحيح | خطأ | نجاح | فشل | فارغ");
}

عدم عرض_الانواع() {
    اكتب_سطر("═══ أنواع البيانات ═══");
    اكتب_سطر("عدد = int     | كسري = float  | مزدوج = double");
    اكتب_سطر("محرف = char  | طويل = long   | قصير = short");
    اكتب_سطر("عدم = void   | صحيح/خطأ = true/false");
}

عدم عرض_مثال_كامل() {
    اكتب_سطر("═══ مثال كامل ═══");
    اكتب_سطر("#ادرج \"سيف_خالص.ع\"");
    اكتب_سطر("عدد رئيسي() {");
    اكتب_سطر("    محرف اسم[50];");
    اكتب_سطر("    اكتب_سطر(\"ما اسمك؟\");");
    اكتب_سطر("    اقرأ_سطر_عربي(اسم, 50);");
    اكتب_سطر("    اكتب(\"مرحبا %s!\\n\", اسم);");
    اكتب_سطر("    ارجع نجاح;");
    اكتب_سطر("}");
}

عدم عرض_الترجمة() {
    اكتب_سطر("═══ ترجمة وتشغيل ═══");
    اكتب_سطر("الترجمة:  ./حداد برنامج.سيف -o برنامج");
    اكتب_سطر("التشغيل:  ./برنامج");
    اكتب_سطر("برياضيات: ./حداد برنامج.سيف -o برنامج -lm");
}

عدد رئيسي() {
    محرف امر[100];
    عدد تشغيل = صحيح;
    
    عرض_عنوان();
    اكتب_سطر("اكتب 'م' للمساعدة | 'خ' للخروج");
    اكتب_سطر("");
    
    طالما (تشغيل) {
        /* RTL marker + prompt */
        اكتب("\x1b[1;32mسيف>\x1b[0m ");
        اقرأ_سطر_عربي(امر, 100);
        
        عدد ط = طول_نص(امر);
        اذا (ط > 0 && امر[ط-1] == '\n') امر[ط-1] = '\0';
        
        /* اختصارات */
        اذا (قارن_نص(امر, "م") == 0 || قارن_نص(امر, "مساعدة") == 0)
            عرض_قائمة_الاوامر();
        والا اذا (قارن_نص(امر, "ك") == 0 || قارن_نص(امر, "كلمات") == 0)
            عرض_الكلمات();
        والا اذا (قارن_نص(امر, "ا") == 0 || قارن_نص(امر, "انواع") == 0)
            عرض_الانواع();
        والا اذا (قارن_نص(امر, "ث") == 0 || قارن_نص(امر, "مثال") == 0)
            عرض_مثال_كامل();
        والا اذا (قارن_نص(امر, "ج") == 0 || قارن_نص(امر, "ترجمة") == 0)
            عرض_الترجمة();
        والا اذا (قارن_نص(امر, "خ") == 0 || قارن_نص(امر, "خروج") == 0) {
            اكتب_سطر("⚔️ مع السلامة! 🇩🇿");
            تشغيل = خطأ;
        }
        والا اذا (طول_نص(امر) > 0) {
            اكتب("⚠️ غير معروف: %s\n", امر);
        }
    }
    
    ارجع نجاح;
}
