#ادرج "سيف_خالص.ع"

#define اقصى_اسطر  500
#define اقصى_حروف  1024

محرف نص[اقصى_اسطر][اقصى_حروف];
عدد عدد_اسطر = 0;
محرف اسم_ملف[256] = "برنامج.سيف";

/* ─────── دوال بسيطة ─────── */

عدد اقرا_مفتاح() {
    محرف م;
    extern int قراءة(int, void*, int);
    قراءة(0, &م, 1);
    
    اذا (م == 27) {
        قراءة(0, &م, 1);
        اذا (م == '[') {
            قراءة(0, &م, 1);
            اذا (م == 'A') ارجع 100;
            اذا (م == 'B') ارجع 101;
            اذا (م == 'C') ارجع 102;
            اذا (م == 'D') ارجع 103;
        }
        ارجع 0;
    }
    
    اذا (م == 10) ارجع 10;
    اذا (م == 127) ارجع 127;
    اذا (م == 19) ارجع 19;
    اذا (م == 17) ارجع 17;
    
    ارجع (عدد)م;
}

عدم احفظ() {
    typedef void ملف_نوع;
    ملف_نوع *م = افتح_ملف(اسم_ملف, وضع_كتابة);
    اذا (م == فارغ) ارجع;
    لكل (عدد ع = 0; ع < عدد_اسطر; ع = ع + 1) {
        اكتب_سطر_ملف(نص[ع], م);
        اكتب_في_ملف("\n", م);
    }
    اغلق_ملف(م);
}

عدد افتح(محرف *ا) {
    typedef void ملف_نوع;
    ملف_نوع *م = افتح_ملف(ا, وضع_قراءة);
    اذا (م == فارغ) ارجع فشل;
    عدد_اسطر = 0;
    بينما (!نهاية_ملف(م) && عدد_اسطر < اقصى_اسطر) {
        اقرا_سطر(نص[عدد_اسطر], اقصى_حروف, م);
        عدد ط = طول_نص(نص[عدد_اسطر]);
        اذا (ط > 0 && نص[عدد_اسطر][ط-1] == '\n') نص[عدد_اسطر][ط-1] = '\0';
        عدد_اسطر = عدد_اسطر + 1;
    }
    اغلق_ملف(م);
    ارجع نجاح;
}

/* ─────── الرئيسية ─────── */
عدد رئيسي(عدد وسائط, محرف *وسيط[]) {
    اكتب("\x1b[2J\x1b[H"); /* مسح الشاشة */
    
    اذا (وسائط > 1) {
        انسخ_نص(اسم_ملف, وسيط[1]);
        افتح(اسم_ملف);
    } والا {
        عدد_اسطر = 1;
        نص[0][0] = '\0';
    }
    
    اكتب_سطر("╔══════════════════════════════════╗");
    اكتب_سطر("║  ✏️ محرر سيف البسيط           ║");
    اكتب_سطر("║  Ctrl+S=حفظ  Ctrl+Q=خروج       ║");
    اكتب_سطر("╚══════════════════════════════════╝");
    اكتب_سطر("");
    
    /* عرض المحتوى الحالي */
    لكل (عدد ع = 0; ع < عدد_اسطر; ع = ع + 1) {
        اكتب("%2d: %s\n", ع + 1, نص[ع]);
    }
    
    اكتب_سطر("─── اكتب الأوامر أدناه ───");
    
    عدد تشغيل = صحيح;
    عدد سطر_جديد = عدد_اسطر;
    
    بينما (تشغيل) {
        اكتب("%2d> ", سطر_جديد + 1);
        اقرأ_سطر_عربي(نص[سطر_جديد], اقصى_حروف);
        
        /* إزالة سطر جديد */
        عدد ط = طول_نص(نص[سطر_جديد]);
        اذا (ط > 0 && نص[سطر_جديد][ط-1] == '\n') نص[سطر_جديد][ط-1] = '\0';
        
        /* أوامر خاصة */
        اذا (قارن_نص(نص[سطر_جديد], ":حفظ") == 0) {
            احفظ();
            اكتب_سطر("   ✅ تم الحفظ!");
            سطر_جديد = سطر_جديد - 1;
        }
        والا اذا (قارن_نص(نص[سطر_جديد], ":خروج") == 0) {
            تشغيل = خطأ;
        }
        والا اذا (قارن_نص(نص[سطر_جديد], ":مساعدة") == 0) {
            اكتب_سطر("   Ctrl+S=حفظ | Ctrl+Q=خروج | :حفظ :خروج :مساعدة");
            سطر_جديد = سطر_جديد - 1;
        }
        والا اذا (قارن_نص(نص[سطر_جديد], ":عرض") == 0) {
            اكتب("\x1b[2J\x1b[H");
            لكل (عدد ع = 0; ع <= سطر_جديد; ع = ع + 1) {
                اكتب("%2d: %s\n", ع + 1, نص[ع]);
            }
            سطر_جديد = سطر_جديد - 1;
        }
        والا {
            /* سطر عادي */
            سطر_جديد = سطر_جديد + 1;
            عدد_اسطر = سطر_جديد;
        }
    }
    
    احفظ();
    اكتب_سطر("⚔️ تم الحفظ والخروج. 🇩🇿");
    ارجع نجاح;
}
