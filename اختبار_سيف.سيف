#ادرج "سيف.ع"

عدد رئيسي() {
    اكتب_سطر("⚔️══════════════════════⚔️");
    اكتب_سطر("   اختبار لغة سيف الشامل");
    اكتب_سطر("⚔️══════════════════════⚔️");
    
    /* اختبار المتغيرات */
    عدد س = 10;
    كسري ص = 3.14;
    محرف ح = 'A';
    اكتب("📊 عدد: %d | كسري: %f | محرف: %c\n", س, ص, ح);
    
    /* اختبار الشرط */
    اذا (س > 5) {
        اكتب_سطر("✅ اذا: الشرط صحيح");
    }
    والا {
        اكتب_سطر("❌ والا: الشرط خطأ");
    }
    
    /* اختبار التكرار */
    عدد ع = 0;
    اكتب_سطر("🔄 طالما: بدء التكرار...");
    طالما (ع < 3) {
        اكتب("   تكرار %d\n", ع);
        ع = ع + 1;
    }
    
    /* اختبار لكل */
    اكتب_سطر("🔁 لكل: بدء التكرار...");
    لكل (عدد م = 0; م < 2; م = م + 1) {
        اكتب("   حلقة %d\n", م);
    }
    
    /* اختبار الذاكرة */
    عدد *مصفوفة = احجز_ذاكرة(3 * sizeof(عدد));
    مصفوفة[0] = 100;
    مصفوفة[1] = 200;
    مصفوفة[2] = 300;
    اكتب("💾 ذاكرة: %d %d %d\n", مصفوفة[0], مصفوفة[1], مصفوفة[2]);
    حرر_ذاكرة(مصفوفة);
    
    /* اختبار النصوص */
    char نص[50];
    انسخ_نص(نص, "السلام عليكم");
    اكتب("📝 طول النص '%s': %lu\n", نص, طول_نص(نص));
    
    /* اختبار الرياضيات */
    اكتب("📐 جذر 25 = %.0f\n", جذر_تربيعي(25));
    اكتب("📐 2 أس 3 = %.0f\n", قوة(2, 3));
    
    /* اختبار عشوائي */
    اكتب("🎲 رقم عشوائي: %d\n", رقم_عشوائي() % 100);
    
    /* اختبار التفرع */
    تفرع (س) {
        حالة 10:
            اكتب_سطر("🎯 تفرع: س = 10");
            توقف;
        افتراضي:
            اكتب_سطر("🎯 تفرع: قيمة أخرى");
    }
    
    اكتب_سطر("⚔️══════════════════════⚔️");
    اكتب_سطر("   ✅ كل الاختبارات نجحت!");
    اكتب_سطر("   🇩🇿 صنع في الجزائر");
    اكتب_سطر("⚔️══════════════════════⚔️");
    
    أرجع نجاح;
}
